---
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Props {
  title: string;
  description: string;
  headings?: MarkdownHeading[];
}

const { title, description, headings = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="flex min-h-[calc(100vh-3.25rem)]">
    <Sidebar />
    <main class="flex-1 min-w-0 max-w-3xl mx-auto px-6 sm:px-10 py-10 prose-doc">
      <h1 class="text-3xl font-semibold tracking-tight mb-6">{title}</h1>
      <slot />
    </main>
    <TableOfContents headings={headings} />
  </div>
</BaseLayout>

<style is:global>
  /* Doc-page prose tuning. Scoped via .prose-doc to keep home-page free. */
  .prose-doc p { margin: 0 0 1rem; color: var(--c-fg); }
  .prose-doc a { color: var(--c-accent-3); }
  .prose-doc strong { color: var(--c-fg); font-weight: 600; }
  .prose-doc ul { padding-left: 1.25rem; margin: 0 0 1rem; list-style: '–  '; }
  .prose-doc li { margin-bottom: 0.35rem; color: var(--c-fg); }
  .prose-doc :not(pre) > code {
    background: var(--c-surface-2);
    border: 1px solid color-mix(in srgb, var(--c-fg) 7%, transparent);
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 0.92em;
    color: var(--c-accent);
  }
  .prose-doc h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }
  .prose-doc h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
  }
  .prose-doc pre {
    background: var(--c-surface-2);
    border: 1px solid var(--c-border);
    border-radius: 4px;
    padding: 1rem 1.1rem;
    margin: 1rem 0;
    overflow-x: auto;
    font-size: 0.9em;
    line-height: 1.65;
  }
  .prose-doc pre code {
    color: var(--c-fg);
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }
</style>
