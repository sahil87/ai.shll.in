---
import DocLayout from '../../layouts/DocLayout.astro';

const title = 'All tools';
const description =
  'Index of the @sahil87 AI coding toolkit — small Go CLIs that compose into a complete AI coding workflow.';

const headings = [
  { depth: 2, slug: 'the-loop', text: 'The loop' },
  { depth: 2, slug: 'wrapping-the-loop', text: 'Wrapping the loop' },
  { depth: 2, slug: 'install-everything', text: 'Install everything' },
];

interface Row {
  slug: string;
  role: string;
}

const loop: Row[] = [
  { slug: 'idea', role: 'Capture — plain-Markdown backlog, feeds <code>/fab-new</code>.' },
  { slug: 'fab-kit', role: 'Spec — 7-stage AI pipeline that plans before coding.' },
  { slug: 'wt', role: 'Isolate — one git worktree per change, one AI session per worktree.' },
  { slug: 'run-kit', role: 'Orchestrate — browser dashboard for tmux + Claude Code workspaces.' },
];

const wrapping: Row[] = [
  { slug: 'hop', role: 'Navigate — fuzzy-cd, batch-git, run-anything across repos.' },
  { slug: 'tu', role: 'Track — token/cost for Claude Code, Codex, OpenCode.' },
  { slug: 'shll', role: 'Maintain — meta-CLI to install, update, and shell-wire the whole toolkit.' },
];
---

<DocLayout title={title} description={description} headings={headings}>
  <p>
    Each tool is a small, single-purpose Go CLI. They work standalone and compose into a loop: capture → spec → parallel agent sessions → ship.
  </p>

  <h2 id="the-loop">The loop</h2>
  <table class="w-full text-sm my-4 border-collapse">
    <thead>
      <tr class="border-b border-border text-left text-fg-dim">
        <th class="py-2 pr-4 font-medium w-32">Tool</th>
        <th class="py-2 font-medium">Role</th>
      </tr>
    </thead>
    <tbody>
      {loop.map(r => (
        <tr class="border-b border-border/40">
          <td class="py-2 pr-4"><a class="text-accent font-semibold no-underline hover:underline" href={`/tools/${r.slug}/`}>{r.slug}</a></td>
          <td class="py-2 text-fg-dim" set:html={r.role}></td>
        </tr>
      ))}
    </tbody>
  </table>

  <h2 id="wrapping-the-loop">Wrapping the loop</h2>
  <table class="w-full text-sm my-4 border-collapse">
    <thead>
      <tr class="border-b border-border text-left text-fg-dim">
        <th class="py-2 pr-4 font-medium w-32">Tool</th>
        <th class="py-2 font-medium">Role</th>
      </tr>
    </thead>
    <tbody>
      {wrapping.map(r => (
        <tr class="border-b border-border/40">
          <td class="py-2 pr-4"><a class="text-accent font-semibold no-underline hover:underline" href={`/tools/${r.slug}/`}>{r.slug}</a></td>
          <td class="py-2 text-fg-dim" set:html={r.role}></td>
        </tr>
      ))}
    </tbody>
  </table>

  <h2 id="install-everything">Install everything</h2>
  <pre><code>brew install sahil87/tap/all
shll shell-install
exec $SHELL</code></pre>

  <p>Or install a single tool — each tool page has its own <code>brew install</code> line.</p>
</DocLayout>
