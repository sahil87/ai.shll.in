---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import HRule from '../components/HRule.astro';
import ToolRow from '../components/ToolRow.astro';
import Diagram from '../components/Diagram.astro';
import { tools } from '../data/tools.ts';

const title = 'A complete AI coding workflow';
const description =
  'Open-source AI coding toolkit by @sahil87 — small Go CLIs that compose into a complete AI coding workflow.';

const tagline =
  'Open-source AI coding toolkit by <a href="https://github.com/sahil87">@sahil87</a>, CTO of <a href="https://noon.design">Noon</a>. Used daily at Noon. No SDK, no vendor lock-in, no opinions you can\'t override.';
---

<BaseLayout title={title} description={description}>
  <main class="mx-auto max-w-3xl px-6 sm:px-10 pt-10 pb-16">
    <Hero
      title={title}
      tagline={tagline}
      actions={[
        { text: 'Install everything →', link: '#install', variant: 'primary', comment: '# one-line brew' },
        { text: 'Browse the tools ↗',   link: '/tools/',  variant: 'secondary', comment: '# 7 small Go CLIs' },
      ]}
    />

    <h2 id="the-loop">The loop</h2>
    <p class="text-fg">
      One idea fans out into many parallel agent sessions — then converges into a single dashboard you can watch from your phone. <code class="px-1.5 py-px rounded-sm bg-surface-2 border border-fg-faint/20 text-accent text-[0.92em]">hop</code> and <code class="px-1.5 py-px rounded-sm bg-surface-2 border border-fg-faint/20 text-accent text-[0.92em]">tu</code> wrap the loop: navigation in, token tracking out.
    </p>

    <Diagram
      light="/diagrams/loop-light.svg"
      dark="/diagrams/loop-dark.svg"
      alt="The toolkit loop: idea, fab-kit, wt, run-kit, hop, tu"
    />

    <p class="text-fg mt-4">
      <strong class="text-fg font-semibold">Inside the loop:</strong>
      <code class="px-1.5 py-px rounded-sm bg-surface-2 border border-fg-faint/20 text-accent text-[0.92em]">idea</code> captures it ·
      <code class="px-1.5 py-px rounded-sm bg-surface-2 border border-fg-faint/20 text-accent text-[0.92em]">fab-kit</code> turns it into a spec the AI can't fudge ·
      <code class="px-1.5 py-px rounded-sm bg-surface-2 border border-fg-faint/20 text-accent text-[0.92em]">wt</code> spins up an isolated worktree per change so N agents work in parallel without conflicts ·
      <code class="px-1.5 py-px rounded-sm bg-surface-2 border border-fg-faint/20 text-accent text-[0.92em]">run-kit</code> gives you one browser tab to watch them all (mobile-friendly via Tailscale).
    </p>

    <p class="text-fg">
      <strong class="text-fg font-semibold">Wrapping the loop:</strong>
      <code class="px-1.5 py-px rounded-sm bg-surface-2 border border-fg-faint/20 text-accent text-[0.92em]">hop</code> jumps you into any worktree (or across repos) in one keystroke ·
      <code class="px-1.5 py-px rounded-sm bg-surface-2 border border-fg-faint/20 text-accent text-[0.92em]">tu</code> tracks what all those parallel agents are costing you in tokens ·
      <code class="px-1.5 py-px rounded-sm bg-surface-2 border border-fg-faint/20 text-accent text-[0.92em]">shll</code> keeps everything installed and updated.
    </p>

    <HRule />

    <h2 id="install">Install</h2>
    <div class="relative bg-surface-2 border border-border rounded-sm my-4 font-mono text-[13px] leading-[1.7]">
      <span class="absolute -top-px -right-px text-[10px] tracking-wider px-2.5 py-0.5 bg-bg text-fg-faint border border-border rounded-tr-sm rounded-bl-sm">bash</span>
      <div class="px-5 py-4">
        <div><span class="text-accent-2 font-semibold">$</span> <span class="text-fg">brew install sahil87/tap/all</span>   <span class="text-fg-faint"># installs every tool in the toolkit</span></div>
        <div><span class="text-accent-2 font-semibold">$</span> <span class="text-fg">shll shell-install</span>             <span class="text-fg-faint"># wire shell integration into your rc file</span></div>
        <div><span class="text-accent-2 font-semibold">$</span> <span class="text-fg">exec $SHELL</span>                    <span class="text-fg-faint"># reload so the integration takes effect</span></div>
      </div>
    </div>
    <p class="text-fg">
      Later, <code class="px-1.5 py-px rounded-sm bg-surface-2 border border-fg-faint/20 text-accent text-[0.92em]">shll update</code> upgrades every installed tool in one go. See the <a class="text-accent-3 underline underline-offset-2" href="https://github.com/sahil87/shll">shll README</a> for the full command surface.
    </p>

    <HRule />

    <h2 id="tools">Tools</h2>
    <div class="font-mono text-sm my-4">
      {tools.map((t, i) => (
        <ToolRow name={t.slug} branch={i === tools.length - 1 ? '└──' : '├──'}>
          <Fragment set:html={t.blurb} />
        </ToolRow>
      ))}
    </div>

    <HRule />

    <h2 id="community">Community</h2>
    <div class="relative my-6 px-5 py-4 border-l-2 border-accent-2 bg-surface">
      <span class="absolute -top-2 left-3 text-[10px] tracking-wider px-2 py-0.5 bg-bg text-accent-2">// community</span>
      <p class="m-0 text-fg">
        Questions, feature requests, or just want to chat about AI dev tooling? <strong class="text-fg font-semibold"><a class="text-accent-3 underline underline-offset-2" href="https://discord.gg/32XHh5mJYn">Join the Discord</a></strong> — that's where I answer queries, share what I'm building, and discuss with people using these tools.
      </p>
    </div>
  </main>
</BaseLayout>
