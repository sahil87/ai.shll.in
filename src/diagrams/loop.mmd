%% Some labels include a trailing &nbsp; so the browser-rendered text fits
%% inside the rect that mermaid pre-measures in headless Chrome. Without it,
%% the "t" in fab-kit/run-kit and the "u" in tu get clipped on the right edge.
flowchart TB
    hop["hop"] -.->|navigate| fab
    idea["idea"] --> fab["fab-kit&nbsp;"]
    fab --> w1["wt + agent #1"]
    fab --> w2["wt + agent #2"]
    fab --> w3["wt + agent #3"]
    w1 --> rk["run-kit&nbsp;"]
    w2 --> rk
    w3 --> rk
    rk --> ship(["ship"])
    rk -.->|tokens| tu["tu&nbsp;"]

    classDef tool fill:transparent,stroke:#d4a73a,stroke-width:1.5px,color:#d4a73a;
    classDef agent fill:transparent,stroke:#7cb342,stroke-width:1.5px,color:#7cb342;
    classDef ship fill:transparent,stroke:#5eb3b3,stroke-width:1.5px,color:#5eb3b3;
    classDef ambient fill:transparent,stroke:#7c8593,stroke-width:1.5px,stroke-dasharray:4 3,color:#7c8593;
    class idea,fab,rk tool;
    class w1,w2,w3 agent;
    class ship ship;
    class hop,tu ambient;
