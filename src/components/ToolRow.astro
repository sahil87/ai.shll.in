---
/**
 * One row of the home-page Tools tree. Each row is a 3-column grid:
 * branch character (├── / └──) · tool name (link) · description with trailing
 * Docs/GitHub links.
 *
 * The description column supports MDX/HTML via the default slot, so callers
 * can embed <code>, inline links, etc. The Docs/GitHub trailing links are
 * generated from `name` since they follow a uniform pattern across the toolkit.
 *
 * Constitution III: styling is Tailwind utilities only; this component exists
 * to dedupe the utility chains across seven rows.
 */
interface Props {
  /** Tool slug, used for both `/tools/{name}/` and `github.com/sahil87/{name}`. */
  name: string;
  /** Tree branch character — typically `├──` for interior rows, `└──` for the last. */
  branch?: string;
}

const { name, branch = '├──' } = Astro.props;
const docsHref = `/tools/${name}/`;
const githubHref = `https://github.com/sahil87/${name}`;
---

<div class="grid grid-cols-[1.5rem_5rem_1fr] gap-3 py-1 items-baseline">
  <span class="text-fg-faint select-none">{branch}</span>
  <a class="text-accent font-semibold no-underline hover:underline" href={docsHref}>{name}</a>
  <span class="text-fg-dim"
    ><slot />{' '}
    <a class="text-accent-3 no-underline hover:underline" href={docsHref}>Docs →</a> ·{' '}
    <a class="text-accent-3 no-underline hover:underline" href={githubHref}>GitHub →</a></span>
</div>
