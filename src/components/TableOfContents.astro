---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const h2s = headings.filter(h => h.depth === 2);
---

{h2s.length > 0 && (
  <aside class="hidden lg:block w-52 shrink-0 border-l border-border px-5 py-7 text-xs self-start sticky top-0">
    <div class="shell-group-label text-fg-dim text-[10px] tracking-[0.14em] uppercase mb-3">On this page</div>
    <nav>
      {h2s.map(h => (
        <a
          href={`#${h.slug}`}
          class="block py-1 pl-3 -ml-3 border-l-2 border-transparent text-fg-dim no-underline hover:text-fg"
        >
          {h.text}
        </a>
      ))}
    </nav>
  </aside>
)}
