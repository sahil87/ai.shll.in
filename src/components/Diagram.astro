---
const { light, dark, alt = '' } = Astro.props as { light: string; dark: string; alt?: string };
---

<img
  class="diagram"
  src={light}
  alt={alt}
  loading="lazy"
  data-light={light}
  data-dark={dark}
/>

<style>
  .diagram {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
  }
</style>

<script>
  // Swap between pre-rendered light/dark SVGs based on the current theme.
  // BaseLayout's inline init script and ThemeToggle both set
  // `data-theme="light" | "dark"` on <html>. We also handle the historical
  // "auto" value by falling back to the OS preference.
  const apply = () => {
    const theme = document.documentElement.dataset.theme ?? 'auto';
    const wantDark =
      theme === 'dark' ||
      (theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches);
    for (const img of document.querySelectorAll<HTMLImageElement>('img.diagram')) {
      const next = wantDark ? img.dataset.dark : img.dataset.light;
      if (next && img.src.endsWith(next) === false) img.src = next;
    }
  };
  apply();
  new MutationObserver(apply).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
  });
  window
    .matchMedia('(prefers-color-scheme: dark)')
    .addEventListener('change', apply);
</script>
