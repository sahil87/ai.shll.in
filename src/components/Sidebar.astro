---
import { tools } from '../data/tools.ts';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';

interface Item {
  label: string;
  href: string;
}

const startHere: Item[] = [{ label: 'Overview', href: '/' }];
const toolItems: Item[] = [
  { label: 'All tools', href: '/tools' },
  ...tools.map(t => ({ label: t.label, href: `/tools/${t.slug}` })),
];

const isActive = (href: string) => href === path;
---

<aside class="hidden md:block w-60 shrink-0 border-r border-border px-5 py-7 text-[13px] self-stretch">
  <div class="mb-7">
    <div class="shell-group-label text-fg-dim text-[10px] tracking-[0.14em] uppercase mb-2.5">Start here</div>
    {startHere.map(item => (
      <a
        href={item.href}
        class:list={[
          'block py-1 pl-2.5 -ml-2.5 border-l-2 no-underline',
          isActive(item.href)
            ? 'text-accent border-accent bg-gradient-to-r from-accent/[0.06] to-transparent'
            : 'text-fg-dim border-transparent hover:text-fg',
        ]}
      >
        {item.label}
      </a>
    ))}
  </div>

  <div>
    <div class="shell-group-label text-fg-dim text-[10px] tracking-[0.14em] uppercase mb-2.5">Tools</div>
    {toolItems.map(item => (
      <a
        href={item.href}
        class:list={[
          'block py-1 pl-2.5 -ml-2.5 border-l-2 no-underline',
          isActive(item.href)
            ? 'text-accent border-accent bg-gradient-to-r from-accent/[0.06] to-transparent'
            : 'text-fg-dim border-transparent hover:text-fg',
        ]}
      >
        {item.label}
      </a>
    ))}
  </div>
</aside>
