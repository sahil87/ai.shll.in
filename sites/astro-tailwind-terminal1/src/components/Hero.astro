---
interface Action {
  text: string;
  link: string;
  variant?: 'primary' | 'secondary';
  comment?: string;
}

interface Props {
  title: string;
  tagline?: string;
  actions?: Action[];
}

const { title, tagline, actions = [] } = Astro.props;
---

<section class="pb-8 mb-8 border-b border-dashed border-border">
  <p class="mb-4 text-xs font-mono text-fg-faint">
    <span class="text-accent-2 font-semibold">~/ai.shll.in</span>{' '}
    <span class="text-fg-dim">$ cat README.md</span>
  </p>

  <h1
    id="_top"
    class="text-3xl sm:text-4xl font-semibold leading-tight tracking-tight mb-4"
  >
    <Fragment set:html={title} /><span
      class="inline-block ml-1 align-baseline translate-y-[0.15em] bg-accent animate-blink motion-reduce:animate-none w-[0.55em] h-[1em]"
      aria-hidden="true"
    ></span>
  </h1>

  {tagline && (
    <div class="mb-7 max-w-[40rem] text-sm text-fg-dim leading-relaxed [&_a]:text-accent-3 [&_a]:underline [&_a]:underline-offset-2" set:html={tagline} />
  )}

  {actions.length > 0 && (
    <div class="flex flex-col gap-2">
      {actions.map(({ link, text, variant, comment }) => (
        <p class="flex items-center gap-3 m-0 text-sm">
          <span class="text-accent-2 font-semibold shrink-0">$</span>
          <a
            href={link}
            class:list={[
              'inline-block px-3.5 py-1.5 no-underline border rounded-sm text-[13px]',
              variant === 'primary'
                ? 'bg-accent border-accent text-bg font-semibold hover:brightness-110'
                : 'border-border bg-surface text-fg hover:bg-surface-2',
            ]}
          >
            {text}
          </a>
          {comment && <span class="text-fg-faint text-xs">{comment}</span>}
        </p>
      ))}
    </div>
  )}
</section>
