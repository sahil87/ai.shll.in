---
/* Cycles Auto → Light → Dark on click. Persists to localStorage('theme').
   Displays as a mockup-style chip: "theme: dark". The actual theme
   application happens in the inline init script in BaseLayout's <head>. */
---

<button
  id="theme-toggle"
  type="button"
  class="text-[11px] text-fg-faint border border-border rounded-sm px-2.5 py-1 hover:text-fg hover:border-fg-faint cursor-pointer bg-transparent font-mono"
  aria-label="Toggle color theme"
>
  theme: <span id="theme-toggle-label">dark</span>
</button>

<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    const label = document.getElementById('theme-toggle-label');
    if (!btn || !label) return;

    const ORDER = ['auto', 'light', 'dark'];
    const resolve = (choice) => {
      if (choice === 'light' || choice === 'dark') return choice;
      return window.matchMedia('(prefers-color-scheme: light)').matches
        ? 'light'
        : 'dark';
    };

    const render = () => {
      const choice = localStorage.getItem('theme') || 'auto';
      label.textContent = choice === 'auto' ? `${resolve(choice)} (auto)` : choice;
      document.documentElement.dataset.theme = resolve(choice);
    };

    btn.addEventListener('click', () => {
      const current = localStorage.getItem('theme') || 'auto';
      const idx = ORDER.indexOf(current);
      const next = ORDER[(idx + 1) % ORDER.length];
      if (next === 'auto') localStorage.removeItem('theme');
      else localStorage.setItem('theme', next);
      render();
    });

    window
      .matchMedia('(prefers-color-scheme: light)')
      .addEventListener('change', render);

    render();
  })();
</script>
