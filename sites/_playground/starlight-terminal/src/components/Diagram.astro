---
const { light, dark, alt = '' } = Astro.props as {
  light: string;
  dark: string;
  alt?: string;
};
---

<img
  class="diagram"
  src={light}
  alt={alt}
  loading="lazy"
  data-light={light}
  data-dark={dark}
/>

<style>
  .diagram {
    display: block;
    width: 100%;
    height: auto;
    /* Intrinsic SVG width is ~586px; capping there prevents Starlight's
       720px content column from scaling the diagram up. Centered so the
       breathing room sits on both sides. */
    max-width: 586px;
    margin: 1.5rem auto;
  }
</style>

<script>
  // Swap between pre-rendered light/dark SVGs based on Starlight's theme.
  // Starlight sets data-theme="light" | "dark" on <html>; ThemeProvider also
  // supports "auto" via prefers-color-scheme.
  const apply = () => {
    const theme = document.documentElement.dataset.theme ?? 'auto';
    const wantDark =
      theme === 'dark' ||
      (theme === 'auto' &&
        window.matchMedia('(prefers-color-scheme: dark)').matches);
    for (const img of document.querySelectorAll<HTMLImageElement>('img.diagram')) {
      const next = wantDark ? img.dataset.dark : img.dataset.light;
      if (next && img.src.endsWith(next) === false) img.src = next;
    }
  };
  apply();
  new MutationObserver(apply).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
  });
  window
    .matchMedia('(prefers-color-scheme: dark)')
    .addEventListener('change', apply);
</script>
